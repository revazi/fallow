{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fallow Review config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "fallowBin": { "type": ["string", "null"], "description": "Path to the fallow binary." },
    "defaultUrl": { "type": "string", "description": "Default URL for live-app / screenshot." },
    "inspectPort": { "type": "number", "description": "Localhost port for the inspector bridge." },
    "agentBackend": {
      "type": "string",
      "enum": ["claude-code", "codex", "opencode"],
      "description": "Default agent backend."
    },
    "diffBase": { "type": ["string", "null"], "description": "Override the diff base ref." }
  }
}
